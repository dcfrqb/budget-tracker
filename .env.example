DB_USER=bdg
DB_PASSWORD=bdg
DB_NAME=budget_tracker
DB_PORT=5433

DATABASE_URL=postgresql://bdg:bdg@localhost:5433/budget_tracker?schema=public

# ── Integrations (Phase J) ────────────────────────────────────────────────────
# Primary key for integration credentials (AES-256-GCM).
# Must be a 64-char hex string (32 bytes).
# Generate with: openssl rand -hex 32
INTEGRATIONS_ENC_KEY=

# Optional: additional key versions for rotation.
# To rotate: add the new key as V2 (or V3, etc.), run:
#   tsx scripts/rotate-integrations-key.ts
# After all rows are migrated, the old key env var can be removed.
# INTEGRATIONS_ENC_KEY_V2=
# INTEGRATIONS_ENC_KEY_V3=

# Set to "true" to enable the bank integrations UI at /settings/integrations.
# Admin-only gate — keeps the feature hidden in production until ready.
ADMIN_INTEGRATIONS=
